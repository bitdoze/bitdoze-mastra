# --- Model (OpenCode Go gateway) ---
# opencode-go provider reads OPENCODE_API_KEY (confirmed via provider registry)
OPENCODE_API_KEY=your-opencode-api-key
AGENT_MODEL=opencode-go/glm-5.2
# Judge model for goal evaluation (can be cheaper/different than main model)
AGENT_JUDGE_MODEL=opencode-go/glm-5.1
# Optional IANA timezone injected into the system prompt (defaults to host tz)
# AGENT_TIMEZONE=Europe/Bucharest

# --- Storage ---
DATABASE_URL=file:./mastra.db

# --- Workspace access ---
# Extra directories the agent's file tools can read/write, in addition to
# ./workspace. Colon-separated absolute paths. Use this to give the agent
# access to other projects on this machine.
# ALLOWED_DIRECTORIES=/home/me/projects/app-a:/home/me/projects/app-b

# Whether shell commands require approval before running. Default: true (safe).
# Set to "false" to run commands without an approval prompt (trusted local use).
# REQUIRE_COMMAND_APPROVAL=false

# --- Memory ---
# Semantic recall uses @mastra/fastembed (local bge-small-en-v1.5 via ONNX
# Runtime). No embedding API key needed; the model downloads on first use.
# Working memory is resource-scoped (persists across threads per resourceId).

# --- TinyFish (web search + fetch, free) ---
TINYFISH_API_KEY=sk-tinyfish-your-key

# --- Browser (AgentBrowser, local Playwright) ---
# Headless by default. Set to "false" for a visible browser window.
# BROWSER_HEADLESS=false
# Optional CDP URL to connect to an external browser (auto-switches to shared scope).
# BROWSER_CDP_URL=ws://localhost:9222

# --- Discord (chat channel) ---
# Get these from https://discord.com/developers/applications > your app
DISCORD_PUBLIC_KEY=your-discord-public-key
DISCORD_APPLICATION_ID=your-discord-application-id
DISCORD_BOT_TOKEN=your-discord-bot-token
# Channel ID where the daily digest workflow posts summaries (right-click a channel > Copy ID)
# DISCORD_DIGEST_CHANNEL_ID=123456789012345678

# --- Auth (SimpleAuth tokens) ---
# Token values are the passwords users enter to log into Studio.
# Pass as ?auth_header=Bearer%20<token> in the Studio URL.
ADMIN_API_KEY=your-admin-token
# MEMBER_API_KEY=your-member-token
